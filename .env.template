# 🔐 BENSON BOT LIVE TRADING CREDENTIALS
# Copy this file to .env and add your real Kraken API credentials

# Kraken API Credentials (Required for Live Trading)
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_SECRET=your_kraken_secret_here

# Trading Safety Settings
LIVE_TRADING_ENABLED=false  # Set to 'true' only when ready for live trading
MAX_DAILY_LOSS=100.0        # Maximum daily loss in USD
EMERGENCY_STOP=false        # Set to 'true' to immediately stop all trading

# Optional: Webhook/Notification Settings
DISCORD_WEBHOOK=           # Discord webhook for trade notifications
SLACK_WEBHOOK=             # Slack webhook for alerts
EMAIL_NOTIFICATIONS=       # Email for critical alerts

# Development/Testing
DEBUG_MODE=false           # Enable debug logging
SIMULATION_MODE=false      # Use simulated prices for testing

# Note: Never commit the actual .env file with real credentials!
# Add .env to your .gitignore file