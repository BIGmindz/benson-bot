cooldown_minutes: 5
csv_log: benson_signals.csv
exchange: kraken
paper_mode: true
paper_trading:
  max_position_size: 18.0
  max_positions: 6
  position_size_pct: 18.0
  starting_balance: 100.0
  stop_loss_pct: 4.0
  take_profit_pct: 8.0
poll_seconds: 30
rsi:
  buy_threshold: 35
  period: 14
  sell_threshold: 65
supply_chain_signals:
  enabled: true
  region: US
  sensitivity: 1.0
symbols:
